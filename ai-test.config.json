{
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-pro",
    "maxTokens": 65536
  },
  "project": {
    "exclude": [
      "node_modules",
      "dist",
      "build",
      ".git",
      "coverage"
    ]
  },
  "webui": {
    "baseUrl": "http://localhost:3000",
    "browser": "chromium",
    "headless": true
  },
  "mcp": {
    "configPath": null,
    "timeout": 10000
  },
  "output": {
    "dir": "./test-results",
    "reportFile": "./test-report.md",
    "screenshots": true
  },
  "coverage": {
    "enabled": false,
    "provider": "v8",
    "thresholds": {
      "lines": 0,
      "branches": 0,
      "functions": 0,
      "statements": 0
    }
  },
  "budget": {
    "maxTokens": 0,
    "confirmBeforeRun": false,
    "pricePerPrompt1k": 0,
    "pricePerCompletion1k": 0
  },
  "ci": {
    "enabled": false,
    "passRateThreshold": 80,
    "jsonReportPath": "./test-results/report.json"
  },
  "interactive": true
}
