    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^1.1.0",
    "@google/genai": "^1.44.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/cli-progress": "^3.11.6",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "detect-port": "^2.0.0",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "playwright": "^1.50.1",
    "tree-kill": "^1.2.2",
    "zod": "^3.24.2",
    "esbuild": "^0.27.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.12.0",
    "p-limit": "^7.3.0",
