{
  "name": "ai-test-tool",
  "version": "0.1.0",
  "description": "AI-powered automated testing CLI tool",
  "type": "module",
  "bin": {
    "ai-test": "./dist/bin/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "dev": "tsx src/bin/cli.ts",
